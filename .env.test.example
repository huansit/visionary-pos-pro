NODE_ENV=sandbox
VISIONPOS_MODE=test
PORT=3001
PUBLIC_APP_URL=https://sandbox.visionarypos.cloud
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/visionary_test
UPLOAD_PATH=/var/visionary/test/uploads
BACKUP_PATH=/var/visionary/test/backups
DEVICE_TOKEN_SECRET=replace-with-a-test-secret-at-least-32-characters
DEVICE_SETUP_KEY=replace-with-a-different-test-secret-at-least-32-characters
CORS_ORIGINS=https://sandbox.visionarypos.cloud,tauri://localhost,http://tauri.localhost,https://tauri.localhost
ADMIN_EMAIL_CODE_REQUIRED=0
