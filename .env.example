NODE_ENV=production
HOST=127.0.0.1
PORT=3000

DATABASE_URL=postgres://visionary_pos:change-me@127.0.0.1:5432/visionary_pos
PGPOOL_MAX=20
PGPOOL_IDLE_TIMEOUT_MS=30000
PGPOOL_CONNECTION_TIMEOUT_MS=5000

# Used to sign device bearer tokens. Generate with: openssl rand -hex 32
DEVICE_TOKEN_SECRET=change-this-long-random-secret

# Optional. If set, POST /api/auth/device must include this setupKey.
DEVICE_SETUP_KEY=change-this-one-time-setup-key

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BCRYPT_ROUNDS=12

# Ask My Business / AI Assistant. Keep this server-side only; never put it in frontend/index.html.
ANTHROPIC_API_KEY=change-me
ANTHROPIC_MODEL=claude-sonnet-4-6

# Owner signup verification codes.
OTP_TTL_MINUTES=10
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=change-me
SMTP_PASS=change-me
SMTP_FROM="Visionary POS <no-reply@visionarypos.cloud>"

# Optional SMS provider. If unset, phone verification returns provider_not_configured.
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=change-me
SMS_FROM=
