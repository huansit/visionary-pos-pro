NODE_ENV=production
VISIONPOS_MODE=live
PORT=3000
PUBLIC_APP_URL=https://visionarypos.cloud
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/visionary_live
UPLOAD_PATH=/var/visionary/live/uploads
BACKUP_PATH=/var/visionary/live/backups
DEVICE_TOKEN_SECRET=replace-with-a-random-secret-at-least-32-characters
DEVICE_SETUP_KEY=replace-with-a-different-random-secret-at-least-32-characters
CORS_ORIGINS=https://visionarypos.cloud,https://www.visionarypos.cloud,tauri://localhost,http://tauri.localhost,https://tauri.localhost
ADMIN_EMAIL_CODE_REQUIRED=1
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@visionarypos.cloud
SMTP_PASS=replace-with-hostinger-email-password
SMTP_FROM=VisionPOS <your-email@visionarypos.cloud>
