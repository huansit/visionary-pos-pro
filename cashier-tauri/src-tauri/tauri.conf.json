{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VISIONPOS Cashier",
  "version": "0.1.0",
  "identifier": "cloud.visionarypos.cashier",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VISIONPOS Cashier",
        "width": 1366,
        "height": 768,
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://visionarypos.cloud; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
